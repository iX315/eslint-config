{
  "name": "@ix315/eslint-config",
  "version": "1.1.0",
  "description": "Shared ESLint config for React, TypeScript, and Next.js projects",
  "main": "index.mjs",
  "types": "types.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "types": "./types.d.ts"
    },
    "./recommended": {
      "import": "./configs/recommended.mjs"
    },
    "./next": {
      "import": "./configs/next.mjs"
    }
  },
  "files": [
    "index.mjs",
    "configs/",
    "types.d.ts"
  ],
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "lint": "eslint ."
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-plugin",
    "typescript",
    "react",
    "next"
  ],
  "author": {
    "name": "Jury Giannelli",
    "email": "ix315@me.com",
    "url": "https://jurygiannelli.dev/"
  },
  "license": "ISC",
  "packageManager": "pnpm@11.8.0",
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.7.1",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "peerDependencies": {
    "eslint": "^10.3.0"
  },
  "devDependencies": {
    "eslint": "^10.3.0"
  }
}
